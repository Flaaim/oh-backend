<?xml version="1.0"?>
<ruleset name="Custom Standard">
    <description>PHP_CodeSniffer configuration with PSR-12 and caching.</description>
    <rule ref="PSR12"/>
    <arg name="extensions" value="php"/>
    <arg value="p"/>
    <arg name="colors"/>
    <arg name="cache" value="./var/cache/.phpcs-cache"/>

    <file>src</file>
    <file>bin</file>
    <file>config</file>
    <file>public</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/var/*</exclude-pattern>
    <exclude-pattern>*/public/index.php</exclude-pattern>
    <exclude-pattern>*/src/Data/Migration</exclude-pattern>
    <exclude-pattern>*/src/*/Test/Unit</exclude-pattern>

    <rule ref="Generic.PHP.LowerCaseType"/>
    <rule ref="Generic.PHP.DisallowShortOpenTag"/>

    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="150"/>
            <property name="absoluteLineLimit" value="170"/>
        </properties>
    </rule>
    <rule ref="Zend.NamingConventions.ValidVariableName.NotCamelCaps"/>
</ruleset>